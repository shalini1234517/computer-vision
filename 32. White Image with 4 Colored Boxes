import cv2
import numpy as np

h = int(input("Enter height: "))
w = int(input("Enter width: "))

img = np.ones((h,w,3),dtype="uint8")*255
s = int(min(h,w)/10)

img[0:s,0:s] = (0,0,0)
img[0:s,w-s:w] = (255,0,0)
img[h-s:h,0:s] = (0,255,0)
img[h-s:h,w-s:w] = (0,0,255)

cv2.imshow("Image",img)
cv2.waitKey(0)
cv2.destroyAllWindows()
